{
  "name": "@agenticos/chat",
  "version": "0.1.0",
  "description": "AgetnticOS Chat Bridge - Multi-channel messaging to AgetnticOS agent system",
  "type": "module",
  "bin": {
    "agenticos-chat": "./dist/bin/agenticos-chat.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/bin/agenticos-chat.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agenticos/cli": "file:../agentic-net-cli",
    "grammy": "^1.35.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "ollama": "^0.5.14",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": ["agenticos", "telegram", "chat", "agent"],
  "license": "SEE LICENSE IN LICENSE.md"
}
