# Multi-stage Dockerfile for agentic-net-chat
# Build context: project root (chat depends on "file:../agentic-net-cli")

FROM node:22-alpine AS builder

WORKDIR /build

# Copy CLI workspace dependency first (for npm install resolution)
COPY agentic-net-cli/ ./agentic-net-cli/

# Copy chat package files for dependency caching
COPY agentic-net-chat/package*.json ./agentic-net-chat/

# Install all dependencies (including devDependencies for tsup build)
WORKDIR /build/agentic-net-chat
RUN npm install

# Copy chat source code
COPY agentic-net-chat/ ./

# Build — tsup bundles @agenticos/cli inline via noExternal
RUN npx tsup

# ---

FROM node:22-alpine AS runtime

# Create non-root user
RUN addgroup -S agenticnet && adduser -S -G agenticnet agenticnet

WORKDIR /app

# Copy package files and install production dependencies only
# (excludes @agenticos/cli since it's bundled inline)
COPY agentic-net-chat/package*.json ./
RUN npm install --omit=dev --ignore-scripts 2>/dev/null || true

# Copy built output from builder
COPY --from=builder /build/agentic-net-chat/dist ./dist

# Change ownership to non-root user
RUN chown -R agenticnet:agenticnet /app

USER agenticnet

# Long-running Telegram bot service
ENTRYPOINT ["node", "dist/bin/agenticos-chat.js"]
