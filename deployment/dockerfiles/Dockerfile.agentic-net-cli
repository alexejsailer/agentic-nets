# Multi-stage Dockerfile for agentic-net-cli
# Build context: agentic-net-cli/

FROM node:22-alpine AS builder

WORKDIR /app

# Copy package files for dependency caching
COPY package*.json ./

# Install all dependencies (including devDependencies for tsup build)
RUN npm install

# Copy source code
COPY . .

# Build ESM bundle
RUN npx tsup

# ---

FROM node:22-alpine AS runtime

# Create non-root user
RUN addgroup -S agenticnet && adduser -S -G agenticnet agenticnet

WORKDIR /app

# Copy package files and install production dependencies only
COPY package*.json ./
RUN npm install --omit=dev

# Copy built output from builder
COPY --from=builder /app/dist ./dist

# Change ownership to non-root user
RUN chown -R agenticnet:agenticnet /app

USER agenticnet

# CLI is a utility container — no exposed port, no health check
ENTRYPOINT ["node", "dist/bin/agenticos.js"]
