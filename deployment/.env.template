# AgetnticOS Agentic-Nets — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# =============================================================================
# Application Image Tags
# =============================================================================
AGENTICOS_NODE_TAG=latest
AGENTICOS_MASTER_TAG=latest
AGENTICOS_EXECUTOR_TAG=latest
AGENTICOS_GATEWAY_TAG=latest
AGENTICOS_GUI_TAG=latest
AGENTICOS_CLI_TAG=latest
AGENTICOS_CHAT_TAG=latest
AGENTICOS_BLOBSTORE_TAG=latest
AGENTICOS_VAULT_TAG=latest

# =============================================================================
# Core Service Ports
# =============================================================================
AGENTIC_NET_NODE_PORT=8080
AGENTIC_NET_MASTER_PORT=8082
AGENTIC_NET_GATEWAY_PORT=8083
AGENTIC_NET_EXECUTOR_PORT=8084
AGENTIC_NET_GUI_PORT=4200
SA_BLOBSTORE_PORT=8090
AGENTIC_NET_VAULT_PORT=8085

# =============================================================================
# Monitoring Ports
# =============================================================================
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
TEMPO_PORT=3200
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318

# =============================================================================
# LLM Configuration
# =============================================================================
# Provider: "ollama" (local) or "claude" (Anthropic API)
LLM_PROVIDER=ollama

# Ollama settings (runs on host — containers reach it via host.docker.internal)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Claude API settings (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=

# =============================================================================
# Security & Credentials
# =============================================================================
# OAuth2 admin secret (auto-generated by gateway on first startup if empty)
AGENTICOS_ADMIN_SECRET=

# Encryption key for persisted system settings (generate a random 64-char hex string)
AGENTICOS_SETTINGS_KEY=

# OpenBao dev root token (used by vault service and master)
OPENBAO_DEV_ROOT_TOKEN=agenticos-dev-token

# Grafana dashboard password
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# Telegram Bot (optional)
# =============================================================================
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_WEBHOOK_BASE_URL=
TELEGRAM_BOT_WEBHOOK_SECRET=
TELEGRAM_BOT_ALLOWED_CHAT_IDS=

# =============================================================================
# Data Persistence
# =============================================================================
# Host directory for node data (events + snapshots)
AGENTICOS_NODE_DATA_DIR=~/.agenticos

# =============================================================================
# Resource Limits
# =============================================================================
AGENTIC_NET_NODE_MEMORY_LIMIT=2G
AGENTIC_NET_NODE_CPU_LIMIT=1.0
AGENTIC_NET_MASTER_MEMORY_LIMIT=2G
AGENTIC_NET_MASTER_CPU_LIMIT=1.0
AGENTIC_NET_EXECUTOR_MEMORY_LIMIT=1G
AGENTIC_NET_EXECUTOR_CPU_LIMIT=0.75
AGENTIC_NET_GATEWAY_MEMORY_LIMIT=1G
AGENTIC_NET_GATEWAY_CPU_LIMIT=0.75
AGENTICOS_CLI_MEMORY_LIMIT=512M
AGENTICOS_CLI_CPU_LIMIT=0.5
AGENTICOS_CHAT_MEMORY_LIMIT=512M
AGENTICOS_CHAT_CPU_LIMIT=0.5
AGENTIC_NET_VAULT_MEMORY_LIMIT=512M
AGENTIC_NET_VAULT_CPU_LIMIT=0.5

# =============================================================================
# Spring Configuration
# =============================================================================
SPRING_PROFILES_ACTIVE=docker
