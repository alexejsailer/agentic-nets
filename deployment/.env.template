# Agentic-Nets Docker Compose environment
#
# Copy this file to .env in the same directory as the compose file:
#
#   cp .env.template .env
#
# Required for a useful first run:
#   1. Choose LLM_PROVIDER.
#   2. Fill the matching API key, or install/pull the Ollama model.
#   3. Change OPENBAO_DEV_ROOT_TOKEN and GATEWAY_INTERNAL_SECRET before
#      sharing the stack on any network.
#
# Extra step if you're running BEHIND A PUBLIC DOMAIN (reverse proxy / TLS):
#   4. Add your public origin to both CORS lists in the Gateway section below
#      (GATEWAY_CORS_ALLOWED_ORIGIN_PATTERNS and
#      AGENTICOS_CORS_ALLOWED_ORIGIN_PATTERNS). Missing this causes login to
#      fail with HTTP 403 "Invalid CORS request" in the browser console.

# =============================================================================
# Release Image Version
# =============================================================================
# Docker Hub image tag for all AgenticNetOS services. Pin this to the release
# you want to run (see CHANGELOG.md for the latest).
AGENTICNETOS_VERSION=2.2.1

# Third-party image pins. Keep these explicit for reproducible local installs.
TEMPO_IMAGE=grafana/tempo:2.10.4
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.135.0
PROMETHEUS_IMAGE=prom/prometheus:v3.11.2
GRAFANA_IMAGE=grafana/grafana:13.0.1
OLLAMA_IMAGE=ollama/ollama:0.21.0

# =============================================================================
# Local Network Binding
# =============================================================================
# 127.0.0.1 keeps all published service ports local to your machine.
# Use 0.0.0.0 only when you intentionally expose this stack to another host.
AGENTICNETOS_BIND_ADDRESS=127.0.0.1

# Core service ports published on AGENTICNETOS_BIND_ADDRESS.
AGENTIC_NET_NODE_PORT=8080
AGENTIC_NET_MASTER_PORT=8082
AGENTIC_NET_GATEWAY_PORT=8083
AGENTIC_NET_EXECUTOR_PORT=8084
AGENTIC_NET_VAULT_PORT=8085
AGENTIC_NET_GUI_PORT=4200
SA_BLOBSTORE_PORT=8090
# Local OCI tool registry. If another registry already owns 5001 on your host,
# set this to a free port such as 5002 before running docker compose.
AGENTICNETOS_REGISTRY_PORT=5001

# Monitoring ports. Used by docker-compose.hub-only.yml; ignored by
# docker-compose.hub-only.no-monitoring.yml.
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
TEMPO_PORT=3200
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318

# =============================================================================
# LLM Provider
# =============================================================================
# Choose one provider: ollama, claude, openai, claude-code, codex.
# For first-time users:
#   - claude: fastest hosted path; set ANTHROPIC_API_KEY.
#   - ollama: local/free path; the compose stack starts an Ollama container for you.
#     The default model below (deepseek-v3.1:671b-cloud) is a *:cloud variant
#     routed through ollama.com — it requires a one-time login, not a pull:
#       docker exec -it agenticnetos-ollama ollama login
#     For a fully local model instead, swap the four OLLAMA_*_MODEL values
#     below (e.g. to llama3.2) and run:
#       docker exec agenticnetos-ollama ollama pull llama3.2
LLM_PROVIDER=ollama
AGENTICOS_MODEL_TIER=medium

# Ollama runs as a service in the compose stack (container: agenticnetos-ollama).
# Backend services reach it via the compose service name "ollama".
# Override only if you prefer to run Ollama on the host (e.g. for GPU access):
#   Docker Desktop (Mac/Windows): http://host.docker.internal:11434
#   Linux-native Docker:          http://172.17.0.1:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_HIGH_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_MEDIUM_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_LOW_MODEL=deepseek-v3.1:671b-cloud

# Resource limits for the bundled Ollama container. Bump these if you plan to
# run larger models (7B/13B+). Cloud-suffixed models (e.g. kimi-k2.5:cloud,
# gpt-oss:120b-cloud) require `ollama login` on the host — see POST_DEPLOYMENT_CONFIG.md.
OLLAMA_MEMORY_LIMIT=8G
OLLAMA_CPU_LIMIT=2.0

# Anthropic Claude. Required when LLM_PROVIDER=claude.
ANTHROPIC_API_KEY=
ANTHROPIC_HIGH_MODEL=claude-opus-4-7
ANTHROPIC_MEDIUM_MODEL=claude-sonnet-4-6
ANTHROPIC_LOW_MODEL=claude-haiku-4-5-20251001

# OpenAI. Required when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_HIGH_MODEL=gpt-5.4
OPENAI_MEDIUM_MODEL=gpt-5.4-mini
OPENAI_LOW_MODEL=gpt-5.4-nano

# =============================================================================
# Security and Local Secrets
# =============================================================================
# Gateway admin secret. Leave empty for local development; gateway generates
# ./data/gateway/jwt/admin-secret on first startup. Set an explicit long random
# value when AGENTICNETOS_BIND_ADDRESS is not 127.0.0.1.
AGENTICOS_ADMIN_SECRET=

# Encryption key used for persisted system settings and transition credentials.
# Leave empty for local evaluation only. For shared environments use a stable
# 32+ character random string and keep it out of git.
AGENTICOS_SETTINGS_KEY=

# OpenBao dev root token. The bundled compose uses OpenBao dev mode for local
# evaluation. Change this value before exposing the stack beyond localhost.
OPENBAO_DEV_ROOT_TOKEN=agenticos-dev-token

# Grafana admin password. Used only by the monitoring compose file.
GRAFANA_ADMIN_PASSWORD=admin

# Internal shared secret for Gateway <-> Master registry calls.
# ⚠️ THIS DEFAULT IS PUBLIC (visible in the .env.template on GitHub). It works
# only for pure-localhost evaluation. Before exposing the stack to any network
# (including a LAN, reverse proxy, or CI runner), replace it with a long random
# value, e.g. generated via:  openssl rand -hex 32
GATEWAY_INTERNAL_SECRET=agenticos-local-internal-secret-change-me

# Browser origins allowed to call Gateway, Master, and Node APIs.
#
# ⚠️  REQUIRED CHANGE WHEN EXPOSING THE GUI BEHIND A PUBLIC HOSTNAME.
#     The defaults below ONLY allow the GUI when you open it from
#     http://localhost:<port> or http://127.0.0.1:<port>. If you put the GUI
#     behind a real domain (Apache/Nginx/Cloudflare reverse proxy at e.g.
#     https://gui.example.com), the browser will send
#     `Origin: https://gui.example.com` and the gateway/master will reject
#     the OAuth2 / API calls with HTTP 403 "Invalid CORS request" — login
#     and every subsequent XHR fails silently in the GUI.
#     Add YOUR public origin to BOTH lists below. Wildcards work, e.g.
#     `https://*.example.com`. Multiple origins comma-separated.
#     Example for a public deployment at https://gui.example.com:
#       GATEWAY_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://gui.example.com
#       AGENTICOS_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://gui.example.com
GATEWAY_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*
AGENTICOS_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

# Gateway proxy timeouts in seconds. Long agent turns and streaming LLM calls
# can need several minutes.
GATEWAY_TIMEOUT=30
GATEWAY_PROXY_TIMEOUT=300

# =============================================================================
# Docker Tool Runtime
# =============================================================================
# Enables agents to start approved OCI tool containers through the local Docker
# socket. Disable if you do not want agent-managed containers in this stack.
AGENTICOS_REGISTRY_ENABLED=true
AGENTICOS_DOCKER_ENABLED=true
AGENTICOS_DOCKER_IMAGE_ALLOWLIST=localhost:5001/agenticos-*

# Optional one-shot registry seeding. The compose service `agenticos-tool-seeder`
# mirrors approved Docker Hub tool images into the local registry above. Keep
# the local registry in the allowlist; agents should run only curated local
# copies, not arbitrary public images.
DOCKER_CLI_IMAGE=docker:28-cli
AGENTICOS_TOOL_REGISTRY_HOST=localhost:5001
AGENTICOS_TOOL_SOURCE_REGISTRY=docker.io/alexejsailer
# Empty means use AGENTICNETOS_VERSION. Set to `latest` only when deliberately
# testing unpinned tool images.
AGENTICOS_TOOL_SEED_TAG=
AGENTICOS_TOOL_SEED_FALLBACK_TAG=latest
# `mirror` pulls from Docker Hub. `build` builds from ../agentic-net-tools and
# pushes to the local registry, useful for contributors changing tool code.
AGENTICOS_TOOL_SEED_MODE=mirror
AGENTICOS_TOOL_SEED_IMAGES=agenticos-tool-echo agenticos-tool-crawler agenticos-tool-rss agenticos-tool-search agenticos-tool-reddit agenticos-tool-secured-api

# =============================================================================
# Telegram Bot (Optional)
# =============================================================================
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_WEBHOOK_BASE_URL=
TELEGRAM_BOT_WEBHOOK_SECRET=
TELEGRAM_BOT_ALLOWED_CHAT_IDS=

# =============================================================================
# Data Persistence
# =============================================================================
# Host directory for agentic-net-node event logs and snapshots.
AGENTICNETOS_NODE_DATA_DIR=~/.agenticos

# =============================================================================
# Resource Limits
# =============================================================================
AGENTIC_NET_NODE_MEMORY_LIMIT=2G
AGENTIC_NET_NODE_CPU_LIMIT=1.0
AGENTIC_NET_MASTER_MEMORY_LIMIT=2G
AGENTIC_NET_MASTER_CPU_LIMIT=1.0
AGENTIC_NET_EXECUTOR_MEMORY_LIMIT=1G
AGENTIC_NET_EXECUTOR_CPU_LIMIT=0.75
AGENTIC_NET_GATEWAY_MEMORY_LIMIT=1G
AGENTIC_NET_GATEWAY_CPU_LIMIT=0.75
AGENTIC_NET_VAULT_MEMORY_LIMIT=512M
AGENTIC_NET_VAULT_CPU_LIMIT=0.5
AGENTICNETOS_CLI_MEMORY_LIMIT=512M
AGENTICNETOS_CLI_CPU_LIMIT=0.5
AGENTICNETOS_CHAT_MEMORY_LIMIT=512M
AGENTICNETOS_CHAT_CPU_LIMIT=0.5

# =============================================================================
# Spring Profile
# =============================================================================
SPRING_PROFILES_ACTIVE=docker
