# SA-BLOBSTORE Docker Compose Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# CLUSTER CONFIGURATION
# =============================================================================

# Minimum and maximum replicas (default: 1 and 2)
MIN_REPLICAS=1
MAX_REPLICAS=2

# Node ports (default: 8081, 8082, 8083)
NODE1_PORT=8081
NODE2_PORT=8082  
NODE3_PORT=8083

# Management/Actuator ports (default: 9091, 9092, 9093)
NODE1_MANAGEMENT_PORT=9091
NODE2_MANAGEMENT_PORT=9092
NODE3_MANAGEMENT_PORT=9093

# Load balancer port (default: 8080)
NGINX_PORT=8080

# =============================================================================
# DATA STORAGE CONFIGURATION  
# =============================================================================

# Data mount type: "local" (bind mount) or "docker" (docker volumes)
# local: Data stored on host filesystem at DATA_PATH
# docker: Data stored in Docker-managed volumes
DATA_MOUNT_TYPE=local

# Local data path (only used when DATA_MOUNT_TYPE=local)
# Data will be stored at: ${DATA_PATH}/node1, ${DATA_PATH}/node2, ${DATA_PATH}/node3
DATA_PATH=./data

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# JVM memory settings
JAVA_OPTS=-Xmx512m -Xms256m

# Upload limits
UPLOAD_MAX_FILE_SIZE=100MB
UPLOAD_MAX_CONCURRENT_UPLOADS=10

# Hash-based storage configuration
HASH_DEPTH=3
HASH_CHARS_PER_LEVEL=2

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# Timeout settings (milliseconds)
TIMEOUT_NETWORK=5000
TIMEOUT_FILE_OPERATION=10000
TIMEOUT_TOTAL_OPERATION=30000

# Cleanup intervals (milliseconds)
CLEANUP_TEMP_FILE_MAX_AGE=1800000
CLEANUP_SCHEDULE_INTERVAL=300000
CLEANUP_ABANDONED_SESSION_TIMEOUT=900000

# Storage settings
DEFAULT_OVERWRITE=false
STORAGE_FORCE_SYNC=true
STORAGE_BUFFER_SIZE=8192

# Upload timeouts (milliseconds)
UPLOAD_TIMEOUT_MS=60000
UPLOAD_ATOMIC_MOVE_TIMEOUT_MS=10000