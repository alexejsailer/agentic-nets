{
  "id": null,
  "title": "AgenticNetOS Test Client Tracing Dashboard",
  "tags": [
    "agenticos",
    "test-client",
    "tracing",
    "tempo"
  ],
  "timezone": "browser",
  "schemaVersion": 27,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "options": [
          {
            "text": "All",
            "value": ".*",
            "selected": true
          },
          {
            "text": "Test Client",
            "value": "agentic-net-test-client",
            "selected": false
          },
          {
            "text": "Node API",
            "value": "agentic-net-node",
            "selected": false
          }
        ],
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "operation",
        "type": "query",
        "query": "label_values(traces{service.name=\"agentic-net-test-client\"}, name)",
        "datasource": "Tempo",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Test Client Status",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=\"agentic-net-test-client\"}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal"
      }
    },
    {
      "id": 2,
      "title": "Active Test Scenarios",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "agenticos_test_scenarios_active_total",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "title": "API Request Success Rate",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "(rate(http_client_requests_seconds_count{application=\"agentic-net-test-client\",status!~\"4..|5..\"}[5m]) / rate(http_client_requests_seconds_count{application=\"agentic-net-test-client\"}[5m])) * 100",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "title": "Average API Response Time",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_client_requests_seconds_bucket{application=\"agentic-net-test-client\"}[5m]))",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "Recent Traces - Test Client Operations",
      "type": "traces",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Tempo",
          "queryType": "traceql",
          "query": "{resource.service.name=\"agentic-net-test-client\"} | select(span.http.method, span.http.url, span.http.status_code, duration) | by(resource.service.name)"
        }
      ],
      "options": {
        "showHeader": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 6,
      "title": "Test Scenario Execution Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "expr": "rate(agenticos_test_scenario_executions_total[5m])",
          "refId": "A",
          "legendFormat": "{{scenario_name}} - {{result}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 3
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "values": [
            "value",
            "max",
            "mean"
          ]
        }
      }
    },
    {
      "id": 7,
      "title": "API Call Distribution by Endpoint",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "targets": [
        {
          "expr": "rate(http_client_requests_seconds_count{application=\"agentic-net-test-client\"}[5m])",
          "refId": "A",
          "legendFormat": "{{method}} {{uri}} ({{status}})",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Cross-Service Request Traces",
      "type": "traces",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Tempo",
          "queryType": "traceql",
          "query": "{resource.service.name=\"agentic-net-test-client\"} && {resource.service.name=\"agentic-net-node\"}"
        }
      ],
      "options": {
        "showHeader": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 9,
      "title": "BlobStore API Operations",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "expr": "rate(agenticos_blobstore_operations_total[5m])",
          "refId": "A",
          "legendFormat": "{{operation}} - {{result}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Test Client Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 36
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"agentic-net-test-client\",area=\"heap\"}",
          "refId": "A",
          "legendFormat": "{{id}} - Used",
          "datasource": "Prometheus"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"agentic-net-test-client\",area=\"heap\"}",
          "refId": "B",
          "legendFormat": "{{id}} - Max",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 11,
      "title": "Concurrent Test Execution",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 36
      },
      "targets": [
        {
          "expr": "agenticos_test_threads_active",
          "refId": "A",
          "legendFormat": "Active Test Threads",
          "datasource": "Prometheus"
        },
        {
          "expr": "agenticos_test_queue_size",
          "refId": "B",
          "legendFormat": "Queued Tests",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Trace Query Builder",
      "type": "traces",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 44
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Tempo",
          "queryType": "traceql",
          "query": "{resource.service.name=~\"${service:regex}\"} | select(span.name, duration, span.http.status_code)"
        }
      ],
      "options": {
        "showHeader": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 13,
      "title": "Error Traces Analysis",
      "type": "traces",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 56
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Tempo",
          "queryType": "traceql",
          "query": "{resource.service.name=\"agentic-net-test-client\"} && {span.status_code=error}"
        }
      ],
      "options": {
        "showHeader": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 14,
      "title": "API Response Time Heatmap",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 66
      },
      "targets": [
        {
          "expr": "increase(http_client_requests_seconds_bucket{application=\"agentic-net-test-client\"}[2m])",
          "refId": "A",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": {
          "unit": "s"
        },
        "color": {
          "mode": "spectrum",
          "scheme": "Spectral"
        }
      }
    }
  ]
}