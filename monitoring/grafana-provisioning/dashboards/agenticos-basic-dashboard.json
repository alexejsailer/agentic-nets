{
  "id": null,
  "title": "AgetnticOS Basic Dashboard",
  "tags": [
    "agenticos",
    "spring-boot"
  ],
  "timezone": "browser",
  "schemaVersion": 27,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Application Status",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=\"agentic-net-node\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal"
      }
    },
    {
      "id": 2,
      "title": "HTTP Requests/sec",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"agentic-net-node\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "title": "JVM Memory Used",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"agentic-net-node\", area=\"heap\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 500000000
              },
              {
                "color": "red",
                "value": 1000000000
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 4,
      "title": "Error Rate %",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"agentic-net-node\",status=~\"4..|5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"agentic-net-node\"}[5m])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 5,
      "title": "CPU Usage",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "system_cpu_usage{job=\"agentic-net-node\"} * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 6,
      "title": "Threads",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"agentic-net-node\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 7,
      "title": "HTTP Request Rate by Endpoint",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum by (uri, method, status) (rate(http_server_requests_seconds_count{job=\"agentic-net-node\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{method}} {{uri}} ({{status}})"
        }
      ],
      "yAxes": [
        {
          "label": "Requests/sec",
          "min": 0
        },
        {
          "show": false
        }
      ],
      "xAxis": {
        "show": true
      },
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "pointradius": 2,
      "legend": {
        "show": true,
        "values": true,
        "current": true,
        "max": true,
        "avg": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2,
        "value_type": "individual"
      }
    },
    {
      "id": 8,
      "title": "Response Times (95th Percentile)",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (uri, le) (rate(http_server_requests_seconds_bucket{job=\"agentic-net-node\"}[5m])))",
          "refId": "A",
          "legendFormat": "{{uri}}"
        }
      ],
      "yAxes": [
        {
          "label": "Response Time (seconds)",
          "min": 0
        },
        {
          "show": false
        }
      ],
      "xAxis": {
        "show": true
      },
      "lines": true,
      "fill": 0,
      "linewidth": 2,
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2,
        "value_type": "individual"
      }
    },
    {
      "id": 9,
      "title": "JVM Memory Usage",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"agentic-net-node\"}",
          "refId": "A",
          "legendFormat": "{{area}} - {{id}}"
        }
      ],
      "yAxes": [
        {
          "label": "Bytes",
          "min": 0
        },
        {
          "show": false
        }
      ],
      "xAxis": {
        "show": true
      },
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "legend": {
        "show": true,
        "values": false,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2,
        "value_type": "individual"
      }
    },
    {
      "id": 10,
      "title": "Garbage Collection Time",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 14
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_collection_seconds_sum{job=\"agentic-net-node\"}[5m])",
          "refId": "A",
          "legendFormat": "{{gc}} GC Time/sec"
        }
      ],
      "yAxes": [
        {
          "label": "Seconds/sec",
          "min": 0
        },
        {
          "show": false
        }
      ],
      "xAxis": {
        "show": true
      },
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2,
        "value_type": "individual"
      }
    },
    {
      "id": 11,
      "title": "Thread States",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 14
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"agentic-net-node\"}",
          "refId": "A",
          "legendFormat": "Live Threads"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=\"agentic-net-node\"}",
          "refId": "B",
          "legendFormat": "Daemon Threads"
        },
        {
          "expr": "jvm_threads_peak_threads{job=\"agentic-net-node\"}",
          "refId": "C",
          "legendFormat": "Peak Threads"
        }
      ],
      "yAxes": [
        {
          "label": "Thread Count",
          "min": 0
        },
        {
          "show": false
        }
      ],
      "xAxis": {
        "show": true
      },
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2,
        "value_type": "individual"
      }
    },
    {
      "id": 12,
      "title": "Available Metrics (Debug)",
      "type": "text",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "options": {
        "mode": "markdown",
        "content": "**Getting Started:**\n\n1. If you see no data, ensure your AgetnticOS application is running: `./mvnw spring-boot:run`\n2. Check Prometheus is scraping: http://localhost:9090/targets\n3. Test metrics endpoint: http://localhost:8080/actuator/prometheus\n4. Generate some traffic: `curl http://localhost:8080/api/tree`\n\n**Available Standard Metrics:**\n- `up{job=\"agentic-net-node\"}` - Application up/down status\n- `http_server_requests_seconds_*` - HTTP request metrics\n- `jvm_memory_*` - JVM memory usage\n- `jvm_threads_*` - Thread information\n- `system_cpu_usage` - CPU utilization\n\n**Next Steps:**\nSee `METRICS_INTEGRATION.md` for adding AgetnticOS-specific metrics like model operations, snapshots, and tree structure data."
      }
    }
  ]
}